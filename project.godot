; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="UnhingedGekko"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=240
window/size/viewport_height=160
window/size/borderless=true
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[layer_names]

2d_physics/layer_1="World"
2d_physics/layer_2="PlayerBody"
2d_physics/layer_3="PlayerHitbox"
2d_physics/layer_4="PlayerHurtbox"
2d_physics/layer_5="EnemyArea"
2d_physics/layer_6="EnemyBody"
2d_physics/layer_7="StoreArea"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
